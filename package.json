{
  "name": "research-assistant-workspace",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "npm run frontend:dev",
    "frontend:dev": "npm --prefix frontend run dev",
    "frontend:build": "npm --prefix frontend run build",
    "frontend:start": "npm --prefix frontend run start",
    "frontend:lint": "npm --prefix frontend run lint",
    "backend:dev": "python -m uvicorn app.main:app --app-dir backend --reload --host 127.0.0.1 --port 4000",
    "backend:start": "python -m uvicorn app.main:app --app-dir backend --host 127.0.0.1 --port 4000"
  }
}
